generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  FULL
  PARTIAL
  PENDING
}

model Company {
  id           String   @id @default(cuid())
  companyName  String
  logoUrl      String?
  signatureUrl String?
  address      String
  phone        String
  email        String
  gstNumber    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String?
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
  @@index([phone])
}

model Vehicle {
  id            Int      @id @default(autoincrement())
  vehicleNumber String   @unique
  vehicleModel  String?
  vehicleType   String?
  invoices      Invoice[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InvoiceCounter {
  id        Int      @id
  current   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  driverId Int
  driver   Driver  @relation(fields: [driverId], references: [id], onDelete: Restrict)

  journeyDate DateTime

  tripFrom String
  tripTo   String

  fromDate      DateTime
  toDate        DateTime
  numberOfDays  Int

  pickupTime  String?
  closingTime String?

  openingKm Int
  closingKm Int
  totalKm   Int

tollCharges    Float  @default(0)
parkingCharges Float  @default(0)

amount         Float
amountReceived Float  @default(0)
balanceAmount  Float

  paymentStatus PaymentStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journeyDate])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([vehicleId])
  @@index([invoiceNumber])
}

